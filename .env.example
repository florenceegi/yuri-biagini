# CREATOR-STAGING — Environment Variables
# Copy to .env.local and fill values

# EGI API
NEXT_PUBLIC_EGI_API_URL=https://art.florenceegi.com/api
NEXT_PUBLIC_ARTIST_ID=

# Sanity CMS (legacy — will be removed when all content comes from EGI API)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# Contact Form
RESEND_API_KEY=
CONTACT_EMAIL_TO=info@florenceegi.com

# Rate Limiting (Upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Site
NEXT_PUBLIC_SITE_URL=https://creator-staging.florenceegi.com
NEXT_PUBLIC_SITE_NAME=Creator Staging

# Site Mode (configurator | production)
SITE_MODE=configurator

# Active Section Addons (M-082) — comma-separated ids from lib/site-catalog.ts SECTIONS
# Empty = base site only (all addon routes 404). Staging default = all on.
NEXT_PUBLIC_ACTIVE_SECTIONS=collections,exhibitions,press,cv,story_behind,process,journal,live,commission

# Analytics
NEXT_PUBLIC_FE_ANALYTICS_SITE_ID=creator-staging
NEXT_PUBLIC_FE_ANALYTICS_ENDPOINT=https://hub.florenceegi.com/api/analytics/collect
