  "story_behind": {
    "eyebrow": "艺术家叙事",
    "title": "每一条线背后的故事",
    "subtitle": "作品之前是动作。动作之前是问题。这就是塑造作品的路径。",
    "manifesto": "我创作,是因为我看到某种尚未存在之物,无法任其不可见。每件作品都是对一个念头许下并兑现的承诺。",
    "origin_title": "起源",
    "origin_body": "我从小就相信绘画是一种倾听。在语言之前,我有双手;在双手之前,我有目光。我的训练不是学校的清单——而是凝视白墙上光线变化的时光。",
    "craft_title": "技艺",
    "craft_body": "技艺是把错误做好的纪律。工作室里的每一天,都是直觉与材料之间的协商。没有作品能在第一次尝试中干净地完成——这正是工作中诚实的部分。",
    "voice_title": "声音",
    "voice_body": "我的声音不是一种风格签名:它是无人注视时我所作决定的总和。这正是为什么某些作品进入一个房间便能改变它。",
    "horizon_title": "远景",
    "horizon_body": "我不为结束而工作。我为开启下一个问题而工作。每件作品都是门槛,而不是答案。",
    "quote": "艺术不是你所见,而是你让别人所见。",
    "quote_author": "埃德加·德加",
    "cta_text": "现在你已经知道路径,是时候与作品一同走过。",
    "cta_label": "探索作品"
  },
  "process": {
    "eyebrow": "过程",
    "title": "走进工作室",
    "subtitle": "一件作品不在某个瞬间诞生。它诞生于五个阶段,反复直至成为语言。",
    "stages_heading": "五个阶段",
    "stage_spark_title": "火花",
    "stage_spark_body": "一切从心中的图像、一个句子、一瞥的光开始。我在理解之前就记下,不让那一刻的温度流失。",
    "stage_spark_duration": "分钟 — 日",
    "stage_sketch_title": "速写",
    "stage_sketch_body": "我拿起纸张。我寻找的不是正确的形式,而是方向。数十个快速变体,不对任何一个产生依恋。",
    "stage_sketch_duration": "日 — 周",
    "stage_build_title": "构建",
    "stage_build_body": "这里开始了身体的劳作。材料、图层、试验、错误。作品开始存在,并开始索求。",
    "stage_build_duration": "周 — 月",
    "stage_refine_title": "精修",
    "stage_refine_body": "我减去的多于添加。每一处细节都被质疑,直到它能独立成立。",
    "stage_refine_duration": "数周",
    "stage_release_title": "释出",
    "stage_release_body": "作品不再属于我。它跨过工作室的门槛,在世界中开始自己的生命。",
    "stage_release_duration": "一瞬",
    "tools_heading": "工具与材料",
    "tool_studio_label": "工作室",
